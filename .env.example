# Local LLM endpoint (OpenAI-compatible API — vLLM, Ollama, etc.)
OPENAI_CHAT_LLM_NAME=gpt-4o
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=your-api-key-here

# LangSmith tracing (optional — remove or leave blank to disable)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=codereview-agent

# Shadow scoring — judge model for async quality evaluation
OPENAI_JUDGE_MODEL=gpt-4o
SHADOW_SCORE_PROBABILITY=0.10
SHADOW_SCORE_THRESHOLD=0.70
